{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/scripts/protect-env.sh"
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "command -v rtk >/dev/null && rtk hook claude || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/scripts/format-on-save.sh",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "command -v atuin >/dev/null && atuin hook claude-code || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/scripts/reflect-nudge.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
